{
  "name": "nostr-tools-ng-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "api": "bun server.mjs",
    "db:reset": "sh scripts/db-reset.sh",
    "db:restore": "sh scripts/db-restore.sh",
    "db:dump": "sh scripts/db-dump.sh",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "check": "bun run lint && bun run lint:css && bun run format:check && bun run typecheck && bun run test",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "bun@1.2.13",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@jsverse/transloco": "^8.3.0",
    "@nostr-dev-kit/ndk": "^3.0.3",
    "@nostr-dev-kit/ndk-cache-dexie": "^2.6.44",
    "nostr-tools": "^2.23.3",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/qrcode": "^1.5.6",
    "angular-eslint": "21",
    "daisyui": "^5.5.19",
    "eslint": "9",
    "eslint-config-prettier": "9",
    "husky": "9",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "prettier": "3",
    "stylelint": "16",
    "stylelint-config-standard": "37",
    "stylelint-config-tailwindcss": "1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8",
    "vitest": "^4.0.8"
  }
}
